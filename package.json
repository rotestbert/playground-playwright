{
  "name": "playground-playwright",
  "version": "1.0.0",
  "description": "AI driven Playwright Test Automation Project",
  "type": "module",
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:codegen": "playwright codegen",
    "test:graphql": "playwright test --project=graphql",
    "test:graphql:ui": "playwright test --project=graphql --ui",
    "test:visual": "playwright test --project=visual",
    "test:visual:ui": "playwright test --project=visual --ui",
    "test:visual:update": "bash scripts/update-snapshots.sh",
    "test:perf": "playwright test --project=performance",
    "test:perf:pages": "playwright test --project=performance --grep \"Page Load\"",
    "test:perf:api": "playwright test --project=performance --grep \"API Load\"",
    "test:perf:report": "playwright test --project=performance && open playwright-report/perf-report.html",
    "test:a11y": "playwright test --project=accessibility",
    "test:a11y:ui": "playwright test --project=accessibility --ui",
    "test:a11y:report": "playwright test --project=accessibility && playwright show-report",
    "db:seed": "node --import tsx/esm scripts/seed.ts",
    "db:cleanup": "node --import tsx/esm scripts/cleanup.ts",
    "lint:tests": "eslint tests/**/*.spec.ts tests/**/*.test.ts",
    "lint:tests:fix": "eslint --fix tests/**/*.spec.ts tests/**/*.test.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@faker-js/faker": "^9.8.0",
    "@playwright/test": "^1.51.0",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^3.1.0",
    "@vitest/ui": "^3.1.0",
    "eslint": "^10.1.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "ws": "^8.18.0"
  }
}
